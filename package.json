{
  "name": "specshield",
  "version": "0.1.0",
  "description": "OpenAPI contract testing tool — validate your API endpoints against your OpenAPI specification automatically",
  "type": "module",
  "bin": {
    "specshield": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openapi",
    "swagger",
    "api-testing",
    "contract-testing",
    "api-validation",
    "testing"
  ],
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "ajv": "^8.16.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.7.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
